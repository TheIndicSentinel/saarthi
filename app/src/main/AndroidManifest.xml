<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Model downloads + any future network calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Voice input (SpeechRecognizer / Whisper.cpp) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- File attachments (photos/videos/documents) go through
         ActivityResultContracts.GetMultipleContents() — a system content
         picker that grants a scoped, temporary read URI for only the file
         the user selects. This never needed broad gallery-read permission;
         READ_MEDIA_IMAGES/VIDEO/AUDIO and the legacy READ_EXTERNAL_STORAGE
         were declared but unused (confirmed 2026-07-15: zero references
         anywhere in the codebase) — removed rather than justified, since
         Play's own "photo and video permissions" review explicitly prefers
         picker-based access over declaring broad media permissions. -->
    <!-- Push notifications (Android 13+) — used by the daily-wisdom card and
         the model-download progress notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keep the daily-wisdom alarm alive through Doze mode. (No exact-alarm
         permission: the reminder feature was removed; the daily 8 AM wisdom
         alarm uses an inexact Doze-friendly alarm.) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Re-arm the daily wisdom alarm after device reboot (cleared by the OS). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!--
        Foreground service keeps the app alive during heavy AI inference and
        model downloads. Without this, Android 14+/Samsung OneUI kills the
        process within 2–10 s.

        CORRECTED 2026-07-17: an earlier version of this comment claimed
        FOREGROUND_SERVICE_DATA_SYNC and its permission were removed in
        Android 16 (API 36). That was false — current Android documentation
        still lists dataSync as a valid type. Since ModelDownloadService now
        declares foregroundServiceType="dataSync" (switched from specialUse —
        see that service's manifest entry for the full reasoning), its
        matching FOREGROUND_SERVICE_DATA_SYNC permission below is REQUIRED:
        every foreground service type needs its own type-specific permission
        declared, and omitting it makes startForeground() throw
        SecurityException on API 34+ — silently caught elsewhere in this
        codebase's defensive try/catch, which is exactly how this would fail
        invisibly if the permission were missing.

        FOREGROUND_SERVICE_SPECIAL_USE remains required too, for
        InferenceService (active LLM inference) and WorkManager's internal
        SystemForegroundService.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Android 11+ package visibility: needed for SpeechRecognizer.isRecognitionAvailable()
         to correctly detect installed speech recognition services. Without this the API
         returns false even when Google/AOSP recognition is available. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- NOTE: android:hasFragileUserData is deliberately ABSENT. It added a
         "keep app data" checkbox to the uninstall dialog; product decision
         (2026-07-03): uninstall must be a clean wipe — models and all data are
         deleted with the app. Kept data also blocked reinstalls whenever the
         APK signature differed, which confused sideload testers. -->
    <!-- NOTE: android:largeHeap is also deliberately ABSENT (removed
         2026-07-19). It was added in commit fb0e0013e alongside
         allowNativeHeapPointerTagging="false" and memtagMode="off" as part
         of a "hardened process protection" bundle for a native SIGSEGV in
         the (since-replaced) MediaPipe engine — but that crash was an ARM
         MTE/pointer-tagging fault in llama.cpp's GGML allocator, which the
         other two flags directly address (see the memtagMode comment
         below); largeHeap only raises the Dalvik/ART JAVA heap ceiling and
         does nothing for native malloc/mmap, which is where this app's
         actual memory risk lives (the multi-GB model, GPU buffers, and
         LiteRT's native allocations, all off-heap via JNI). It never had
         its own justification — it just rode along with the real fix. -->
    <application
        android:name=".SaarthiApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Saarthi.SplashScreen"
        android:enableOnBackInvokedCallback="true"
        android:allowNativeHeapPointerTagging="false"
        android:memtagMode="off"
        android:networkSecurityConfig="@xml/network_security_config">
        <!--
            Required for litertlm-android GPU (OpenCL) and NPU (QNN) backends.
            Both are optional — absent = backend falls back to CPU automatically.
        -->
        <uses-native-library android:name="libOpenCL.so"      android:required="false" />
        <uses-native-library android:name="libvndksupport.so" android:required="false" />

        <!--
            memtagMode="off": Disables ARM MTE (Memory Tagging Extension) for this process.

            Verified facts as of 2026-07-19 (git history, not speculation):
             - Added 2026-05-02 (fb0e0013e) to stop MTE on ARMv9 devices (Android 16+)
               from converting a silent llama.cpp/GGML out-of-bound NEON write into a
               hard SIGSEGV, under the MediaPipe-based engine of that time.
             - The engine was fully replaced the very next day, 2026-05-03 (60e2f4f),
               by litertlm-android (Google AI Edge LiteRT-LM) — this app has not run
               llama.cpp/GGML code since. The CMake patch once referenced here (removing
               android_armv9 GGML backend variants) no longer exists in this repo; it
               went with the vendored llama.cpp build.
             - In ~2.5 months of active native-crash diagnosis since that migration
               (SM8550 GPU/OpenCL, NPU/QNN SIGKILL, XNNPACK CPU allocation, Conversation-
               recycling SIGKILL — see git log for `fix(inference)` / `fix: ... crash`),
               none were attributed to MTE or pointer tagging.
             - NOT verified: whether LiteRT-LM's own native (C++) allocator is untagged
               in a way MTE would fault on — it wasn't audited, only observed to not have
               produced a crash yet, and this app has not been tested on real ARMv9/MTE
               hardware (Android 16+ MTE-capable devices remain a small slice of this
               app's mid-range-India-focused install base).

            Kept "off" defensively: cost is zero on non-MTE hardware (the overwhelming
            majority of this app's target devices), so there's no upside to removing an
            unproven-safe flag ahead of real MTE-hardware validation.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Reminder + daily-wisdom alarm receiver.
            Two actions land here:
              · com.saarthi.app.REMINDER       — user-scheduled reminder
              · com.saarthi.app.DAILY_WISDOM   — 8 AM daily wisdom card
            The receiver itself routes by action; one class, one channel.
        -->
        <receiver
            android:name=".ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.saarthi.app.DAILY_WISDOM" />
            </intent-filter>
        </receiver>

        <!--
            Re-arms the daily wisdom alarm on reboot. Must be exported=true
            because BOOT_COMPLETED is delivered by the system, and gated by
            the RECEIVE_BOOT_COMPLETED permission so only the system can fire it.
        -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
            Foreground service that keeps the process alive during AI model inference.

            foregroundServiceType="specialUse" is used here. NOTE (corrected
            2026-07-17): a prior version of this comment claimed dataSync was
            removed in Android 16 — that was wrong. Current Android
            documentation still lists dataSync and does not identify LLM
            inference as a case dataSync covers, so specialUse remains the
            better fit for THIS service; the removal claim specifically was
            inaccurate and should not be used to justify the choice.
        -->
        <service
            android:name="com.saarthi.core.inference.InferenceService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device AI model inference (LLM text generation)" />
        </service>

        <!--
            WorkManager uses this internal service to run Foreground Workers.
            Override is required to declare a foregroundServiceType before
            Android 14+ enforces one.

            specialUse is used here, same as InferenceService (see that
            service's comment above — the "dataSync was removed" justification
            was corrected 2026-07-17; it was factually wrong, though it
            doesn't change the type choice for this WorkManager-internal
            component). tools:node="merge" preserves WorkManager's own service
            attributes (exported, process, etc.) while adding our type +
            special-use property.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="specialUse"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="AI model file download (background, resumable via OkHttp)" />
        </service>

        <!--
            User-initiated model download foreground service.

            Replaces the WorkManager/JobScheduler download path, which OEM
            Android skins (OxygenOS/ColorOS/RealmeUI, MIUI, FuntouchOS, One UI
            deep-sleep) refuse to dispatch for non-whitelisted apps — the job
            sits in ENQUEUED forever even with all constraints satisfied
            (reproduced on OnePlus CPH2487, Android 14).

            Started directly from the user's "Download" tap, so the Android 12+
            foreground-service start is permitted; the ongoing notification then
            keeps it alive across every OEM ROM.

            foregroundServiceType="dataSync" — RESOLVED 2026-07-17 (was
            specialUse; an earlier comment incorrectly justified that with a
            claim that dataSync was removed in Android 16, which is false).
            Android's own guidance describes dataSync as covering exactly
            this ("data upload or download... transfer data between a device
            and the cloud over a network"), and specialUse is meant only when
            no standard type fits — dataSync fits, so it's the more correct,
            better-justified choice for Play review.

            The real tradeoff: dataSync gets a system-enforced 6 cumulative
            background hours per rolling 24h window (API 35+), after which
            the system calls Service.onTimeout() and expects stopSelf()
            within seconds. specialUse has no such limit. This is handled:
            ModelDownloadService.onTimeout() stops cleanly rather than
            letting the OS throw, and the timer resets whenever the user
            brings the app to the foreground — so it only binds for a
            download left completely untouched for many hours straight. Even
            then, no data is lost: the partial tmp file is unaffected by how
            the service stops, and reattachActiveDownloads() resumes it via
            Range the next time the app opens, the same as any other service
            death this design already handles.

            InferenceService stays specialUse — active LLM inference isn't a
            data-transfer operation, so dataSync's own type description
            doesn't fit it the way it fits this service.
        -->
        <service
            android:name="com.saarthi.core.inference.ModelDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
            Lets the Support screen attach saarthi_debug.log to an email even
            when it lives in app-private storage (the production default —
            see DebugLogger.shareableUri()). Never exposes the whole app
            sandbox: file_paths.xml scopes it to exactly the directories the
            log can be written to, and android:exported=false + grantUriPermissions
            mean access is only ever a temporary, per-Intent grant to whichever
            app the user picks in the share sheet — nothing is world-readable.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
