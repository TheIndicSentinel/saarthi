<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Model downloads + any future network calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Money Mentor: on-device SMS analysis -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <!-- Voice input (SpeechRecognizer / Whisper.cpp) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- File attachments — media (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- File attachments — legacy (Android ≤ 12) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Model file access from Downloads on Android 11+.
         Required because GGUF model files (≥800MB) are too large for app-private storage
         and must be read from the user-selected Downloads directory.
         Play Store listing must declare this use in the policy form. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <!-- Push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Exact alarms for reminders (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Keep alarms alive through Doze mode -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!--
        Foreground service keeps the app alive during heavy AI inference.
        Without this, Android 14+/Samsung OneUI kills the process within 2–10 s.

        ⚠️  ANDROID 16 (API 36) BREAKING CHANGE:
        FOREGROUND_SERVICE_DATA_SYNC and its associated permission were removed in API 36.
        Declaring them causes startForeground() to throw SecurityException, which is
        silently caught, leaving the app with NO foreground service protection.
        The Android LMK then kills the CPU-heavy process in ~10 s — this was the
        root cause of the crashes seen in the logs.

        Only FOREGROUND_SERVICE_SPECIAL_USE is declared and safe on API 29–36+.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!--
        Required to request battery optimization exemption at runtime.
        Without this, Samsung OneUI 7 (Android 16) kills CPU-heavy processes in 13–60s
        even when a FOREGROUND_SERVICE_SPECIAL_USE is running. Once the user grants
        "Unrestricted" battery usage, the process is shielded from the power watchdog.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!--
        Remove FOREGROUND_SERVICE_DATA_SYNC that MediaPipe's AAR injects via manifest merge.
        This permission was removed in Android 16 (API 36); keeping it in the merged manifest
        causes startForeground() to throw SecurityException on API 36 devices (e.g. SM-S918B),
        silently leaving the app with no foreground protection and the LMK killing it in ~10s.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:node="remove" />

    <!-- Android 11+ package visibility: needed for SpeechRecognizer.isRecognitionAvailable()
         to correctly detect installed speech recognition services. Without this the API
         returns false even when Google/AOSP recognition is available. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".SaarthiApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Saarthi.SplashScreen"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true"
        android:hasFragileUserData="true"
        android:allowNativeHeapPointerTagging="false"
        android:memtagMode="off">
        <!--
            memtagMode="off": Disables ARM MTE (Memory Tagging Extension) for this process.
            llama.cpp's GGML allocator does not tag memory allocations, so MTE on ARMv9
            devices (Android 16+) converts previously-silent NEON kernel out-of-bound
            writes into hard SIGSEGV crashes. The SVE2 root cause is addressed via the
            CMake patch that removes android_armv9 GGML backend variants. This flag is a
            secondary safeguard for any remaining untagged allocations in llama.cpp.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Reminder alarm receiver -->
        <receiver
            android:name=".ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.saarthi.app.REMINDER" />
            </intent-filter>
        </receiver>

        <!--
            Foreground service that keeps the process alive during AI model inference.

            foregroundServiceType="specialUse" — the correct type for on-device LLM
            inference on Android 10+ (API 29+) through Android 16 (API 36+).

            DO NOT add "dataSync" here. FOREGROUND_SERVICE_TYPE_DATA_SYNC was removed
            in Android 16 (API 36). Including it causes startForeground() to throw
            SecurityException → FGS silently degrades → LMK kills the process mid-inference.
        -->
        <!--
            tools:replace prevents the manifest merger from appending "|dataSync" from
            MediaPipe's AAR manifest. Without this, the merged type becomes "specialUse|dataSync"
            which fails validation on Android 16 (API 36) where dataSync was removed.
        -->
        <service
            android:name="com.saarthi.core.inference.InferenceService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:replace="android:foregroundServiceType">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device AI model inference (LLM text generation)" />
        </service>

    </application>
</manifest>
