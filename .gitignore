local.properties
# Signing keys / keystores — NEVER commit, anywhere in the tree. The upload
# keystore lives only on your machine + CI secrets (KEYSTORE_BASE64). Losing it
# is recoverable (reset upload key in Play Console); leaking it is not.
*.jks
*.keystore
keystore/*.jks
keystore/*.keystore
# EXCEPTION: the shared DEBUG keystore is deliberately committed. It is NOT a
# secret — it signs debug/test builds only (standard android/android debug
# credentials, the same convention as Android's own auto-generated debug key)
# and cannot publish to Play. Committing it gives every CI run the SAME debug
# signature, so a new Saarthi.apk installs OVER the previous one instead of
# failing with a signature mismatch. The RELEASE upload key stays uncommitted
# (CI secret only).
!ci/debug.keystore

# Secrets — never commit. Pack signing private key lives in .keys/ (offline);
# Firebase config is intentionally absent (no telemetry).
.keys/
*.pem
google-services.json

# Kotlin compiler transient session files
.kotlin/

# Local dev scratch — one-off regex-edit scripts and captured crash/debug logs
fix_*.py
scratchpad_*.py
debug_*.py
*_crash_log.txt
*_human_log.txt
